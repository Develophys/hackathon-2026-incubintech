POSTGRES_DB=zelo
POSTGRES_USER=zelo
POSTGRES_PASSWORD=devpassword
DATABASE_URL=postgresql://zelo:devpassword@postgres:5432/zelo?schema=public
DIRECT_DATABASE_URL=postgresql://zelo:devpassword@postgres:5432/zelo?schema=public
# "groq" (default) uses real Groq API calls and requires GROQ_API_KEY.
# "mock" swaps in canned AI responses for local dev/testing — no API key, no token spend.
AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
