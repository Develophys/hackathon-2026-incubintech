  "name": "@zelo/api",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "postinstall": "prisma generate",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/main.js",
    "dev": "tsx watch src/main.ts",
    "lint": "eslint src",
